        { "id": "P3-F1-C2", "name": "Two-Factor Authentication", "type": "EI", "complexity": "H", "description": "TOTP-based 2FA for admin accounts", "status": "roadmap" },
        { "id": "P3-F1-C3", "name": "Admin Role Management", "type": "EI", "complexity": "A", "description": "Assign roles and permissions to admins", "status": "roadmap" },
        { "id": "P3-F1-C4", "name": "Admin User List", "type": "EQ", "complexity": "A", "description": "View all admin users", "status": "roadmap" },
        { "id": "P3-F1-C5", "name": "Admin Users Data Store", "type": "ILF", "complexity": "A", "description": "Admin accounts and roles storage", "status": "roadmap" }
      ]
    },
    {

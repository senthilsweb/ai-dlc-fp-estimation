        { "id": "P3-F2-C5", "name": "Seat Inventory Update", "type": "EI", "complexity": "A", "description": "Adjust available seats and classes", "status": "roadmap" },
        { "id": "P3-F2-C6", "name": "Pricing Management", "type": "EI", "complexity": "H", "description": "Set and update fare prices", "status": "roadmap" },
        { "id": "P3-F2-C7", "name": "Schedule Import (Bulk)", "type": "EI", "complexity": "H", "description": "Import flight schedules from CSV/API", "status": "roadmap" },
        { "id": "P3-F2-C8", "name": "Flights Data Store", "type": "ILF", "complexity": "H", "description": "Flight inventory database", "status": "roadmap" }
      ]
    },
    {

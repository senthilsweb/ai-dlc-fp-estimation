        { "id": "P3-F3-C3", "name": "Modify Booking (Admin)", "type": "EI", "complexity": "H", "description": "Change flight, seats, passengers", "status": "roadmap" },
        { "id": "P3-F3-C4", "name": "Process Refund", "type": "EI", "complexity": "H", "description": "Initiate and process refunds", "status": "roadmap" },
        { "id": "P3-F3-C5", "name": "Resend Confirmation", "type": "EO", "complexity": "L", "description": "Resend booking confirmation email", "status": "roadmap" },
        { "id": "P3-F3-C6", "name": "Booking Notes", "type": "EI", "complexity": "L", "description": "Add internal notes to booking", "status": "roadmap" }
      ]
    },
    {
      "id": "P3-F4",
      "name": "Customer Support Tools",
      "description": "Tools for customer service representatives",
      "status": "roadmap",
      "capabilities": [
        { "id": "P3-F4-C1", "name": "Customer Lookup", "type": "EQ", "complexity": "A", "description": "Search customers by name, email, phone", "status": "roadmap" },
        { "id": "P3-F4-C2", "name": "Customer Booking History", "type": "EQ", "complexity": "A", "description": "View all bookings for a customer", "status": "roadmap" },
        { "id": "P3-F4-C3", "name": "Support Ticket View", "type": "EQ", "complexity": "A", "description": "View customer support tickets", "status": "roadmap" },
        { "id": "P3-F4-C4", "name": "Escalation Workflow", "type": "EI", "complexity": "A", "description": "Escalate issues to supervisor", "status": "roadmap" },
        { "id": "P3-F4-C5", "name": "Support Tickets Data", "type": "ILF", "complexity": "A", "description": "Customer support ticket storage", "status": "roadmap" }
      ]
    },
    {
      "id": "P3-F5",
      "name": "Reports & Analytics",
      "description": "Business intelligence and operational reports",
      "status": "roadmap",
      "capabilities": [
        { "id": "P3-F5-C1", "name": "Revenue Dashboard", "type": "EO", "complexity": "H", "description": "Revenue metrics and trends", "status": "roadmap" },
        { "id": "P3-F5-C2", "name": "Occupancy Report", "type": "EO", "complexity": "A", "description": "Flight occupancy and load factors", "status": "roadmap" },
        { "id": "P3-F5-C3", "name": "Booking Trends", "type": "EO", "complexity": "A", "description": "Booking volume over time", "status": "roadmap" },
        { "id": "P3-F5-C4", "name": "Popular Routes", "type": "EO", "complexity": "A", "description": "Top routes by bookings and revenue", "status": "roadmap" },
        { "id": "P3-F5-C5", "name": "Report Export", "type": "EO", "complexity": "A", "description": "Export reports to CSV/PDF", "status": "roadmap" },
        { "id": "P3-F5-C6", "name": "Analytics Data Store", "type": "ILF", "complexity": "H", "description": "Aggregated analytics data", "status": "roadmap" }

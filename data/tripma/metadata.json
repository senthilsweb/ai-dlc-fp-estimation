  "fpConfig": {
    "methodology": "IFPUG CPM 4.3.1",
    "fpWeights": {
      "EI": {
        "L": 3,
        "A": 4,
        "H": 6,
        "name": "External Input",
        "description": "An elementary process that processes data or control information from outside the application boundary.",
        "examples": [
          "Flight search form",
          "Passenger details entry",
          "Payment form submission"
        ]
      },
      "EO": {
        "L": 4,
        "A": 5,
        "H": 7,
        "name": "External Output",
        "description": "An elementary process that generates data or control information sent outside the application boundary.",
        "examples": [
          "Booking confirmation PDF",
          "Email itinerary",
          "Price comparison report"
        ]
      },
      "EQ": {
        "L": 3,
        "A": 4,
        "H": 6,
        "name": "External Inquiry",
        "description": "An elementary process that retrieves data from ILF/EIF without calculations or derived data.",
        "examples": [
          "Flight search results",
          "Seat availability check",
          "Booking details view"
        ]
      },
      "ILF": {
        "L": 7,
        "A": 10,
        "H": 15,
        "name": "Internal Logical File",
        "description": "A user-identifiable group of logically related data maintained within the application boundary.",
        "examples": [
          "Bookings table",
          "User profiles",
          "Payment records"
        ]
      },
      "EIF": {
        "L": 5,
        "A": 7,
        "H": 10,
        "name": "External Interface File",
        "description": "A user-identifiable group of logically related data referenced but not maintained by the application.",
        "examples": [
          "Airline schedules API",
          "Airport codes reference",
          "Currency exchange rates"
        ]
      }
    },

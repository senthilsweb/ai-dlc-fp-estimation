# =============================================================================
# fp-estimator — Function Point Estimator Configuration
# =============================================================================
# Copy to .env and adjust as needed:
#   cp .env.example .env
# =============================================================================

# --- Server ---
# Change this if 8080 is already taken by something else.
FP_PORT=8080

# --- Dev mode ---
# true: serve app/ and data/ live from disk (no rebuild to see edits, must run
# from the repo root). false/unset: serve the embedded copies (production).
FP_DEV=false

# --- Active dataset ---
# Selects which data/<name>/ partition the server loads by default.
# Run without a value and hit /api/apps to see what's available under data/.
# Any dataset can also be requested per-call via /api/data?app=<name>
# (no access control gates this — it's a plain read-only static dataset switch).
FP_APP=ai-agents-provly

# --- Logging ---
FP_LOG_LEVEL=info
# FP_LOG_FORMAT=json
